# Verifiable randomness worker

PORT=3000
NODE_ENV=production
APP_ENVIRONMENT=production
ENVIRONMENT=production
APP_VERSION=0.1.7-BETA

# x402 payment
PAYMENT_WALLET=
PAYMENT_WALLET_BASE=
# EVM pay-to for Robinhood Chain USDG (defaults to PAYMENT_WALLET_BASE)
PAYMENT_WALLET_ROBINHOOD=
X402_FACILITATOR_URL=https://facilitator.payai.network
# RH-capable facilitator (e.g. https://api.solvador.com). Required to advertise eip155:4663 accepts.
# X402_FACILITATOR_URL_ROBINHOOD=
# Or: X402_ROBINHOOD_ENABLED=true  (uses default Solvador URL)
# SUPPORTED_NETWORKS is derived at runtime (solana,base[,robinhood])

# RPCs used to help clients build payment transactions
HELIUS_RPC_URL=
BASE_RPC_URL=
# Robinhood Chain (eip155:4663) — prefer Alchemy/QuickNode in production
ROBINHOOD_RPC_URL=

# Optional runtime tuning
ARWEAVE_ENABLED=true
PHALA_APP_ID=
PHALA_CLUSTER=prod5
REDIS_URL=
