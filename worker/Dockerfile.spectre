# Spectre / amd64 builder: base on previous GHCR release when Docker Hub is unreachable.
FROM ghcr.io/thomasjvu/vrf-service:0.1.8-BETA.4
USER root
WORKDIR /app
COPY package.json tsconfig.json ./
COPY src ./src
COPY static ./static
COPY CHANGELOG.md .
RUN npm install \
 && npm run build \
 && mkdir -p dist/static \
 && cp static/*.js dist/static/ \
 && npm prune --omit=dev
USER appuser
ENV PORT=3000
EXPOSE 3000
CMD ["node", "dist/index.js"]
